# Octop Environment Variables
#
# Copy to deploy/.env or export before `docker compose up`.
# For bare-metal installs, many of these can also live in ~/.octop/env.

# Runtime
OCTOP_PORT=8088
OCTOP_LOG_LEVEL=info
OCTOP_BIND_HOST=0.0.0.0

# Docker first-run bootstrap (only used when ~/.octop/octop.db is absent)
OCTOP_ADMIN_USERNAME=admin
OCTOP_DEFAULT_PASSWORD=octop
OCTOP_ADMIN_DISPLAY_NAME=Admin

# Common LLM provider credentials (optional — can configure in dashboard)
OPENAI_API_KEY=
DASHSCOPE_API_KEY=

# Langfuse observability (optional)
OCTOP_LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=
